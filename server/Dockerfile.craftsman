FROM node:22-bookworm

RUN apt-get update && apt-get install -y git curl tmux sudo iptables && rm -rf /var/lib/apt/lists/*

# Install Docker daemon + CLI (full static distribution — each craftsman runs its own dockerd)
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then ARCH="aarch64"; elif [ "$ARCH" = "x86_64" ]; then ARCH="x86_64"; fi && \
    curl -fsSL "https://download.docker.com/linux/static/stable/${ARCH}/docker-27.5.1.tgz" | \
    tar xz --strip-components=1 -C /usr/local/bin

# Install Docker Compose v2 as CLI plugin + symlink for hyphenated syntax
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then ARCH="aarch64"; elif [ "$ARCH" = "x86_64" ]; then ARCH="x86_64"; fi && \
    mkdir -p /usr/local/lib/docker/cli-plugins && \
    curl -fsSL "https://github.com/docker/compose/releases/download/v2.32.4/docker-compose-linux-${ARCH}" \
      -o /usr/local/lib/docker/cli-plugins/docker-compose && \
    chmod +x /usr/local/lib/docker/cli-plugins/docker-compose && \
    ln -s /usr/local/lib/docker/cli-plugins/docker-compose /usr/local/bin/docker-compose

# Entrypoint: start this container's own Docker daemon, wait for it, then exec CMD
RUN echo '#!/bin/bash' > /usr/local/bin/craftsman-entrypoint.sh \
 && echo 'set -e' >> /usr/local/bin/craftsman-entrypoint.sh \
 && echo 'sudo sh -c "dockerd --log-level=error >/var/log/dockerd.log 2>&1" &' >> /usr/local/bin/craftsman-entrypoint.sh \
 && echo 'until sudo docker info >/dev/null 2>&1; do sleep 0.2; done' >> /usr/local/bin/craftsman-entrypoint.sh \
 && echo 'sudo chmod 666 /var/run/docker.sock' >> /usr/local/bin/craftsman-entrypoint.sh \
 && echo 'exec "$@"' >> /usr/local/bin/craftsman-entrypoint.sh \
 && chmod +x /usr/local/bin/craftsman-entrypoint.sh

RUN npm install -g @anthropic-ai/claude-code@latest

RUN useradd -m -s /bin/bash craftsman \
 && mkdir -p /workspace \
 && chown craftsman:craftsman /workspace

# Grant craftsman passwordless sudo
RUN echo 'craftsman ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/craftsman && \
    chmod 0440 /etc/sudoers.d/craftsman

WORKDIR /workspace
USER craftsman

# Pre-configure Claude Code to skip interactive onboarding + project trust dialog.
RUN echo '{"hasCompletedOnboarding":true,"projects":{"/workspace/project":{"hasTrustDialogAccepted":true,"allowedTools":[],"mcpContextUris":[],"mcpServers":{},"enabledMcpjsonServers":[],"disabledMcpjsonServers":[]}}}' > /home/craftsman/.claude.json

VOLUME /var/lib/docker
ENTRYPOINT ["craftsman-entrypoint.sh"]
CMD ["tail", "-f", "/dev/null"]
