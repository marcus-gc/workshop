FROM node:22-bookworm

RUN apt-get update && apt-get install -y git curl tmux && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code@latest

RUN useradd -m -s /bin/bash craftsman \
 && mkdir -p /workspace \
 && chown craftsman:craftsman /workspace

WORKDIR /workspace
USER craftsman

# Pre-configure Claude Code to skip interactive login/onboarding
RUN echo '{"hasCompletedOnboarding":true}' > /home/craftsman/.claude.json

CMD ["tail", "-f", "/dev/null"]
